#!/usr/bin/env bash
# Deploy seam for card-stage: provider API keys are resolved lazily in TypeScript
# (see _shared/llm/keys.ts — env → macOS Keychain → Doppler, cached per process), so this
# wrapper only execs the entrypoint. card-stage uses Fireworks (draft) + qwencloud (fidelity);
# Fireworks' key lives in the Keychain (service: fireworks-api) and all keys in Doppler.
set -u
exec bun "$(dirname "$(readlink -f "$0")")/../src/cards/card-stage.ts" "$@"
