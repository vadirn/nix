#!/usr/bin/env bash
# Deploy seam for distill-text: provider API keys are resolved lazily in TypeScript
# (see _shared/llm/keys.ts — env → macOS Keychain → Doppler, cached per process), so this
# wrapper only execs the entrypoint. distill uses OpenAI (extract) + qwencloud/DashScope
# (fidelity); their keys live in Doppler (claude-code/std).
set -u
BIN="$(dirname "$(readlink -f "$0")")"
exec bun --preload "$BIN/_alias.ts" "$BIN/../src/distill/app/distill.ts" "$@"
