#!/usr/bin/env bash
# Deploy seam for polish-text: provider API keys are resolved lazily in TypeScript
# (see _shared/llm/keys.ts — env → macOS Keychain → Doppler, cached per process), so this
# wrapper only execs the entrypoint. polish runs on Fireworks; its key lives in the Keychain
# (service: fireworks-api) and Doppler (claude-code/std).
set -u
exec bun "$(dirname "$(readlink -f "$0")")/../src/polish/polish.ts" "$@"
