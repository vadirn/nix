// Zed settings
//
// Managed by home-manager (symlinked from ~/nix/home/zed/settings.json).
// Docs: https://zed.dev/docs/configuring-zed
{
  "auto_install_extensions": {
    "catppuccin": true
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "ui_font_family": "MonoLisaText",
  "ui_font_size": 13,
  "buffer_font_family": "MonoLisaCode",
  "buffer_font_size": 13.0,
  "buffer_font_features": {
    "liga": true,
    "zero": true,
    "ss02": true,
    "ss04": true,
    "ss07": true,
    "ss08": true,
    "ss09": true,
    "ss10": true
  },
  "markdown_preview_font_family": "Literata",
  "markdown_preview_code_font_family": "MonoLisaCode",
  "git_panel": {
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "hard_tabs": true,
  "format_on_save": "on",
  "features": {
    "edit_prediction_provider": "zed"
  },
  "languages": {
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      }
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      }
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      }
    },
    "Svelte": {
      "formatter": "language_server",
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports": true
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.fixAll.stylelint": true
      }
    },
    "Markdown": {
      "formatter": {
        "external": {
          "command": "oxfmt",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "show_edit_predictions": false
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"]
    }
  }
}
