theme = dark:"Catppuccin Mocha",light:"Catppuccin Latte"
font-family = "MonoLisa Variable"
font-size = 13
font-feature = zero
font-variation = "wght=560"
cursor-style = block
cursor-style-blink = true
adjust-cursor-thickness = 200%
keybind = shift+enter=text:\x1b\r
keybind = super+s=text:\x13
keybind = super+left=text:\x1b[H
keybind = super+right=text:\x1b[F
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf
keybind = super+backspace=text:\x15
keybind = super+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = super+up=text:\x1b[1;5H
keybind = super+down=text:\x1b[1;5F
confirm-close-surface = false
unfocused-split-opacity = 0.4
window-colorspace = display-p3
copy-on-select = clipboard