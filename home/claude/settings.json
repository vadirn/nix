{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Skill(writing-ru)",
      "Skill(writing-en)",
      "Skill(firecrawl)",
      "Skill(playwright-cli)",
      "Skill(playground)",
      "Skill(reflect)",
      "Skill(tdd)",
      "Skill(debate)",
      "WebSearch",
      "WebFetch",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(firecrawl *)",
      "Bash(playwright-cli *)",
      "Bash(obsidian *)",
      "Bash(timeout 30 obsidian *)",
      "Skill(obsidian-cli)",

      "Skill(session-stats)",
      "Skill(vault)",
      "Bash(vault-cli *)",
      "Bash(/Users/vadim/.claude/skills/vault/scripts/vault-cli *)",
      "Bash(python3 /Users/vadim/.claude/skills/session-stats/session-stats.py *)",
      "Bash(/Users/vadim/.claude/skills/session-stats/session-stats.py *)",
      "Bash(bunx @tobilu/qmd *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(readlink *)",
      "Bash(jq *)",
      "Bash(base64 *)",
      "Bash(ps *)",
      "Bash(stat *)",
      "Skill(tool-stats)",
      "Bash(python3 /Users/vadim/.claude/skills/tool-stats/tool-stats.py *)",
      "Read(/Users/vadim/.claude/skills/**)"
    ],
    "deny": [
      "Read(.env*)",
      "Grep(.env)",
      "Read(**/credentials*)",
      "Bash(rm -rf:*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git branch -D *)",
      "Bash(git branch -D:*)",
      "Bash(obsidian eval *)",
      "Bash(obsidian delete * permanent*)",
      "Bash(obsidian plugin:install *)",
      "Bash(obsidian plugin:uninstall *)",
      "Bash(obsidian dev:cdp *)",
      "Bash(obsidian command *)",
      "Bash(obsidian history:restore *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh UserPromptSubmit",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Stop",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Notification",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh TaskCompleted",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh PostToolUseFailure",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-git-c.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./.claude-plans",
  "teammateMode": "tmux"
}
