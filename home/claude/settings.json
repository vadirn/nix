{
  "skillListingBudgetFraction": 0.015,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "MAX_STRUCTURED_OUTPUT_RETRIES": "3",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "BASECAMP_NO_KEYRING": "1",
    "BASECAMP_HINTS": "false",
    "BASECAMP_STATS": "false",
    "CLAUDE_CODE_WORKFLOWS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Skill(cut)",
      "Skill(firecrawl-cli)",
      "Skill(firecrawl-search)",
      "Skill(firecrawl-scrape)",
      "Skill(firecrawl-crawl)",
      "Skill(firecrawl-map)",
      "Skill(firecrawl-download)",
      "Skill(firecrawl-agent)",
      "Skill(firecrawl-instruct)",
      "Skill(playground)",
      "Skill(reflect)",
      "Skill(tdd)",
      "Skill(debate)",
      "WebSearch",
      "WebFetch",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git ls-tree *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh pr create *)",
      "Bash(firecrawl *)",
      "Skill(vault)",
      "Skill(pr)",
      "Bash(bunx @tobilu/qmd *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(readlink *)",
      "Bash(jq *)",
      "Bash(base64 *)",
      "Bash(ps *)",
      "Bash(stat *)",
      "Bash(echo *)",
      "Read"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Notification",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-tool-format.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^Edit$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/queue-format.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/no-dangerous-rm.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/no-dangerous.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-network-abuse.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/quiet-override.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pipe-allow.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/require-pr-body-file.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/rg-glob-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets-read.sh"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets-read.sh"
          }
        ]
      },
      {
        "matcher": "^(WebSearch|WebFetch)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/prefer-firecrawl.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /tmp/claude",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Stop",
            "timeout": 5,
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/flush-format-queue.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-verify.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh TaskCompleted",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "outputStyle": "default",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "mcp-proxy.anthropic.com",
        "downloads.claude.ai",
        "raw.githubusercontent.com",
        "browser-intake-datadoghq.com",
        "http-intake.logs.datadoghq.com",
        "api.firecrawl.dev",
        "github.com",
        "api.github.com",
        "lfs.github.com",
        "crates.io",
        "static.crates.io",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "api.doppler.com",
        "cli.doppler.com",
        "generativelanguage.googleapis.com",
        "api.fireworks.ai",
        "dashscope-intl.aliyuncs.com",
        "api.openai.com",
        "fal.run",
        "*.fal.run",
        "*.fal.media",
        "*.fal.ai",
        "*.localhost"
      ],
      "allowManagedDomainsOnly": false,
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.bun",
        "~/.cache",
        "~/.config/basecamp",
        "~/.docker",
        "~/.gnupg",
        "~/Documents/vault",
        "~/nix",
        "~/Pictures/imagen",
        "~/Pictures/vidgen",
        "$TMPDIR"
      ],
      "denyRead": ["~/.ssh"],
      "allowRead": ["~/.ssh/*.pub"]
    },
    "credentials": {
      "files": [
        { "path": "~/.aws", "mode": "deny" },
        { "path": "~/.netrc", "mode": "deny" },
        { "path": "~/.claude/.credentials.json", "mode": "deny" }
      ]
    },
    "enableWeakerNetworkIsolation": true
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "plansDirectory": "./.claude-plans",
  "autoDreamEnabled": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
