{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Skill(writing-ru)",
      "Skill(writing-en)",
      "Skill(firecrawl)",
      "Skill(playwright-cli)",
      "Skill(playground)",
      "Skill(reflect)",
      "Skill(tdd)",
      "Skill(debate)",
      "WebSearch",
      "WebFetch",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git ls-tree *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh pr create *)",
      "Bash(firecrawl *)",
      "Bash(playwright-cli *)",
      "Bash(obsidian *)",
      "Bash(timeout 30 obsidian *)",
      "Skill(obsidian-cli)",
      "Skill(session-stats)",
      "Skill(vault)",
      "Skill(pr)",
      "Bash(vault-cli *)",
      "Bash(session-stats *)",
      "Bash(bunx @tobilu/qmd *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(file *)",
      "Bash(readlink *)",
      "Bash(jq *)",
      "Bash(base64 *)",
      "Bash(ps *)",
      "Bash(stat *)",
      "Bash(echo *)",
      "Skill(tool-stats)",
      "Bash(tool-stats *)",
      "Read"
    ],
    "deny": []
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Notification",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh PostToolUseFailure",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/no-dangerous-rm.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-dangerous.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-network-abuse.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/quiet-override.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pipe-allow.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets-read.sh"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/no-secrets-read.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh SessionStart",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh Stop",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh TaskCompleted",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sound.sh UserPromptSubmit",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "firecrawl@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./.claude-plans",
  "teammateMode": "tmux"
}
