#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
SCHEMA_DIR="$SCRIPT_DIR/../schemas"
QMD="bunx @tobilu/qmd"
QMD_MARKER="$HOME/.cache/qmd/.vault-ready"
VAULT_ROOT=""
PROJECT_PATH=""
PROJECTS_PATH=""
PROJECT_FLAG=""

# --- Config resolution ---

validate_config() {
  local cfg="$1"
  local schema="$2"
  local errors
  if ! errors=$(bunx ajv-cli validate -s "$schema" -d "$cfg" 2>&1); then
    echo "Error: invalid config $cfg" >&2
    echo "$errors" >&2
    echo "" >&2
    echo "Expected schema: $schema" >&2
    exit 1
  fi
}

resolve_config() {
  # Layer 1: Walk up from cwd for project config
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    local cfg="$dir/.claude/.vault.config.json"
    if [[ -f "$cfg" ]]; then
      validate_config "$cfg" "$SCHEMA_DIR/project.config.schema.json"
      local fields
      fields=$(jq -r '[.vault_root, .project_path] | @tsv' "$cfg")
      VAULT_ROOT=$(cut -f1 <<< "$fields")
      PROJECT_PATH=$(cut -f2 <<< "$fields")
      break
    fi
    dir="$(dirname "$dir")"
  done

  # Layer 2: Root config for vault_root and projects_path
  local root_cfg="$HOME/.claude/.vault.config.json"
  if [[ -f "$root_cfg" ]]; then
    validate_config "$root_cfg" "$SCHEMA_DIR/root.config.schema.json"
    local root_fields
    root_fields=$(jq -r '[.vault_root, .projects_path] | @tsv' "$root_cfg")
    [[ -z "$VAULT_ROOT" ]] && VAULT_ROOT=$(cut -f1 <<< "$root_fields")
    PROJECTS_PATH=$(cut -f2 <<< "$root_fields")
  fi

  # Layer 3: --project flag overrides PROJECT_PATH
  if [[ -n "$PROJECT_FLAG" ]]; then
    if [[ -z "$VAULT_ROOT" ]]; then
      echo "Error: --project requires vault_root (set in root or project config)" >&2
      exit 1
    fi
    local pp="${PROJECTS_PATH:-41 projects}"
    PROJECT_PATH="$VAULT_ROOT/$pp/$PROJECT_FLAG"
  fi

  # Require vault_root from config
  if [[ -z "$VAULT_ROOT" ]]; then
    echo "Error: no vault config found." >&2
    echo "Create ~/.claude/.vault.config.json with:" >&2
    echo '  { "vault_root": "/absolute/path/to/vault", "projects_path": "41 projects" }' >&2
    exit 1
  fi
}

# --- Helpers ---

ensure_collection() {
  [[ -f "$QMD_MARKER" ]] && return
  $QMD collection add "$VAULT_ROOT" --name vault --mask "**/*.md" >&2 2>/dev/null || true
  $QMD update >&2
  $QMD embed >&2
  mkdir -p "$(dirname "$QMD_MARKER")"
  touch "$QMD_MARKER"
}

# --- Subcommands ---

require_project() {
  if [[ -z "$PROJECT_PATH" ]]; then
    echo "Error: no project resolved (use --project <name> or add .claude/.vault.config.json)" >&2
    exit 1
  fi
}

cmd_config() {
  local json
  json=$(jq -n --arg vr "$VAULT_ROOT" --arg pp "$PROJECTS_PATH" --arg ppath "$PROJECT_PATH" \
    '{vault_root: $vr} + (if $pp != "" then {projects_path: $pp} else {} end) + (if $ppath != "" then {project_path: $ppath} else {} end)')
  echo "$json"
}

cmd_context() {
  require_project
  if [[ -f "$PROJECT_PATH/context.md" ]]; then
    cat "$PROJECT_PATH/context.md"
  fi
}

cmd_checkpoints() {
  require_project

  local view="${1:-All}"
  # Derive relative path from vault root for obsidian base:query
  local rel_path="${PROJECT_PATH#"$VAULT_ROOT/"}"
  local base_path="$rel_path/Checkpoints.base"

  # Try obsidian base:query
  if timeout 30 obsidian base:query path="$base_path" view="$view" 2>/dev/null; then
    return
  fi

  # Fallback: grep checkpoint files
  echo "# Fallback: file-based checkpoint listing" >&2
  local pattern="$PROJECT_PATH/checkpoint-*.md"
  case "$view" in
    Incomplete) grep -l "done: false" $pattern 2>/dev/null || true ;;
    Done)       grep -l "done: true" $pattern 2>/dev/null || true ;;
    *)          ls $pattern 2>/dev/null || true ;;
  esac
}

cmd_get() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: vault-cli get <name-fragment>" >&2
    exit 1
  fi
  local fragment="$1"
  local matches=()
  local search_dirs
  if [[ -n "$PROJECT_PATH" ]]; then
    search_dirs=("$PROJECT_PATH")
  else
    search_dirs=("$VAULT_ROOT/00 inbox" "$VAULT_ROOT/10 references" "$VAULT_ROOT/20 cards" "$VAULT_ROOT/30 notes" "$VAULT_ROOT/41 projects")
  fi

  # Replace dashes with wildcards to handle qmd handelized paths (spaces→dashes)
  local fuzzy="${fragment//-/*}"

  while IFS= read -r -d '' file; do
    matches+=("$file")
  done < <(find "${search_dirs[@]}" \
    -iname "*${fuzzy}*.md" -type f -print0 2>/dev/null | sort -z)

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "No matches for '$fragment'" >&2
    exit 1
  elif [[ ${#matches[@]} -eq 1 ]]; then
    echo "${matches[0]}"
    echo "---"
    cat "${matches[0]}"
  else
    for m in "${matches[@]}"; do
      echo "$m"
    done
  fi
}

cmd_search() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: vault-cli search <query> [-n N]" >&2
    exit 1
  fi
  ensure_collection
  local query="$1"
  shift
  $QMD query "$query" -c vault "$@"
}

cmd_update() {
  ensure_collection
  $QMD update
  $QMD embed
}

cmd_projects() {
  # Try obsidian base:query
  if timeout 30 obsidian base:query path="90 bases/Projects.base" view="Активные проекты" 2>/dev/null; then
    return
  fi

  # Fallback: find project notes
  echo "# Fallback: file-based project listing" >&2
  find "$VAULT_ROOT/41 projects" -maxdepth 2 -name '*.md' -not -name 'checkpoint-*' -not -name 'context.md' -not -name 'SKILL.md' -not -name 'start.md' -not -name 'save.md' | sort
}

get_field() {
  local field="$1"
  local fm="$2"
  local val
  val=$(printf '%s\n' "$fm" | sed -n "s/^${field}: *//p" | head -1)
  if [[ -n "$val" ]]; then
    printf '%s' "$val"
    return
  fi
  local in_field=false
  local items=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^${field}:[[:space:]]*$ ]]; then
      in_field=true
      continue
    fi
    if $in_field; then
      if [[ "$line" =~ ^[[:space:]]+-[[:space:]]+(.*) ]]; then
        [[ -n "$items" ]] && items="$items, "
        items="${items}${BASH_REMATCH[1]}"
      else
        break
      fi
    fi
  done <<< "$fm"
  printf '%s' "$items"
}

strip_wikilinks() {
  local s="$1"
  s="${s//\"/}"
  while [[ "$s" =~ \[\[([^]|]*)\|([^]]*)\]\] ]]; do
    s="${s//"${BASH_REMATCH[0]}"/"${BASH_REMATCH[2]}"}"
  done
  while [[ "$s" =~ \[\[([^]]*)\]\] ]]; do
    s="${s//"${BASH_REMATCH[0]}"/"${BASH_REMATCH[1]}"}"
  done
  printf '%s' "$s"
}

strip_brackets() {
  local s="$1"
  s="${s#\[}"
  s="${s%\]}"
  printf '%s' "$s"
}

# List markdown files with frontmatter metadata
# Usage: list_notes <dir> [extra_fields...]
# Always shows: title, description, tags. Extra fields appended as "(field: value)".
list_notes() {
  local notes_dir="$1"
  shift
  local extra_fields=("$@")

  find "$notes_dir" -name '*.md' -type f | sort | while IFS= read -r file; do
    title="$(basename "$file" .md)"
    fm=$(extract_frontmatter "$file")
    [[ -z "$fm" ]] && continue

    desc=$(get_field "description" "$fm")
    tags=$(get_field "tags" "$fm")
    tags=$(strip_brackets "$tags")

    line="$title"
    [[ -n "$desc" ]] && line="$line — $desc"
    [[ -n "$tags" ]] && line="$line [$tags]"

    for ef in "${extra_fields[@]}"; do
      val=$(get_field "$ef" "$fm")
      val=$(strip_wikilinks "$val")
      [[ -n "$val" ]] && line="$line ($ef: $val)"
    done

    printf '%s\n' "$line"
  done
}

cmd_cards() {
  list_notes "$VAULT_ROOT/20 cards" "reference"
}

extract_frontmatter() {
  local file="$1"
  local fm=""
  local in_fm=false
  while IFS= read -r line; do
    if [[ "$line" == "---" ]]; then
      if $in_fm; then break; fi
      in_fm=true
      continue
    fi
    if $in_fm; then
      fm+="$line"$'\n'
    fi
  done < "$file"
  printf '%s' "$fm"
}

# Detect GNU vs BSD date once
if date --version >/dev/null 2>&1; then
  IS_GNU_DATE=true
else
  IS_GNU_DATE=false
fi

iso_week_for_date() {
  local d="${1:-$(date +%Y-%m-%d)}"
  if $IS_GNU_DATE; then
    date -d "$d" +%G-W%V
  else
    date -j -f "%Y-%m-%d" "$d" +%G-W%V
  fi
}

week_start_end() {
  local week="$1"
  local year="${week%%-W*}"
  local wnum="${week##*-W}"
  if $IS_GNU_DATE; then
    local start end
    start=$(date -d "${year}-01-04 +$((( ${wnum#0} - 1) * 7)) days -$(date -d "${year}-01-04" +%u) days +1 day" +%Y-%m-%d)
    end=$(date -d "$start +6 days" +%Y-%m-%d)
  else
    local jan4_dow start end
    jan4_dow=$(date -j -f "%Y-%m-%d" "${year}-01-04" +%u)
    start=$(date -j -v+"$(( (${wnum#0} - 1) * 7 - jan4_dow + 1 ))d" -f "%Y-%m-%d" "${year}-01-04" +%Y-%m-%d)
    end=$(date -j -v+6d -f "%Y-%m-%d" "$start" +%Y-%m-%d)
  fi
  printf '%s\t%s' "$start" "$end"
}

# Offset a date by N days (positive = forward, negative = backward)
date_offset_days() {
  local d="$1" n="$2"
  if $IS_GNU_DATE; then
    date -d "$d + $n days" +%Y-%m-%d
  else
    if [[ $n -ge 0 ]]; then
      date -j -v+"${n}d" -f "%Y-%m-%d" "$d" +%Y-%m-%d
    else
      date -j -v"${n}d" -f "%Y-%m-%d" "$d" +%Y-%m-%d
    fi
  fi
}

days_in_month() {
  local y="$1" m="$2"
  local next_m=$((10#$m + 1)) next_y="$y"
  if [[ $next_m -gt 12 ]]; then
    next_m=1
    next_y=$((y + 1))
  fi
  local first_of_next
  first_of_next=$(printf '%04d-%02d-01' "$next_y" "$next_m")
  date_offset_days "$first_of_next" -1 | cut -d- -f3
  # Returns zero-padded day, caller should use $((10#...)) if needed
}

cmd_xp() {
  local today
  today=$(date +%Y-%m-%d)
  local year="${1:-${today%%-*}}"
  local log_dir="$VAULT_ROOT/41 projects/block-buster"

  # Single pass over weekly files: collect task counts and coverage bonuses
  declare -A day_tasks day_bonus
  for f in "$log_dir"/week-*.md; do
    [[ -f "$f" ]] || continue
    local content
    content=$(<"$f")

    # Task counts
    local in_t=false
    local done_links=()
    while IFS= read -r line; do
      if [[ "$line" =~ ^##[[:space:]]+Tasks ]]; then in_t=true; continue; fi
      if $in_t && [[ "$line" =~ ^## ]]; then break; fi
      if $in_t && [[ "$line" =~ ^-[[:space:]]\[x\][[:space:]]\(([0-9]{4}-[0-9]{2}-[0-9]{2})\) ]]; then
        local d="${BASH_REMATCH[1]}"
        day_tasks["$d"]=$(( ${day_tasks["$d"]:-0} + 1 ))
        local tmp="$line"
        while [[ "$tmp" =~ \[\[([^]|]*)\]\] ]]; do
          done_links+=("${BASH_REMATCH[1]}")
          tmp="${tmp#*"${BASH_REMATCH[0]}"}"
        done
      fi
    done <<< "$content"

    # Coverage bonus (inline weekly_bonus logic to avoid re-reading)
    local fm week_id
    fm=$(extract_frontmatter "$f")
    week_id=$(get_field "week" "$fm")
    local projects=() in_p=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^##[[:space:]]+Projects ]]; then in_p=true; continue; fi
      if $in_p && [[ "$line" =~ ^## ]]; then break; fi
      if $in_p && [[ "$line" =~ \[\[([^]|]*)\]\] ]]; then
        projects+=("${BASH_REMATCH[1]}")
      fi
    done <<< "$content"

    if [[ ${#projects[@]} -gt 0 && ${#done_links[@]} -gt 0 ]]; then
      local all_covered=true
      for p in "${projects[@]}"; do
        local found=false
        for dl in "${done_links[@]}"; do
          [[ "$dl" == "$p" ]] && { found=true; break; }
        done
        $found || { all_covered=false; break; }
      done
      if $all_covered; then
        local start_end monday
        start_end=$(week_start_end "$week_id")
        monday=$(date_offset_days "$(cut -f1 <<< "$start_end")" 7)
        day_bonus["$monday"]=$(( ${day_bonus["$monday"]:-0} + ${#projects[@]} ))
      fi
    fi
  done

  # Sleep streak: collect dates into associative array, walk once
  declare -A sleep_set
  local sleep_raw
  sleep_raw=$(collect_sleep_dates)
  if [[ -n "$sleep_raw" ]]; then
    while IFS= read -r sd; do
      sleep_set["$sd"]=1
    done <<< "$sleep_raw"
  fi

  local streak=0
  local streak_dates=()
  local si=1
  while true; do
    local check
    check=$(date_offset_days "$today" "-$si")
    if [[ -n "${sleep_set[$check]:-}" ]]; then
      streak_dates+=("$check")
      si=$((si + 1))
    else
      break
    fi
  done
  if [[ -n "${sleep_set[$today]:-}" ]]; then
    streak_dates+=("$today")
  fi
  streak=${#streak_dates[@]}

  declare -A day_streak
  if [[ $streak -gt 0 ]]; then
    local sday=1
    for sd in $(printf '%s\n' "${streak_dates[@]}" | sort); do
      local sb=$((sday > 7 ? 7 : sday))
      day_streak["$sd"]=$sb
      sday=$((sday + 1))
    done
  fi

  # Build output
  local year_total=0
  local out=""
  local dim=$'\033[2m' reset=$'\033[0m' green=$'\033[32m'
  local cur_month="${today:5:2}"
  cur_month=$((10#$cur_month))
  local is_current_year=false
  [[ "$year" == "${today%%-*}" ]] && is_current_year=true

  # Year header
  local nl=$'\n'
  if $is_current_year; then
    local day_of_year days_in_year pct
    if $IS_GNU_DATE; then
      day_of_year=$(date -d "$today" +%j)
      days_in_year=$(date -d "${year}-12-31" +%j)
    else
      day_of_year=$(date -j -f "%Y-%m-%d" "$today" +%j)
      days_in_year=$(date -j -f "%Y-%m-%d" "${year}-12-31" +%j)
    fi
    day_of_year=$((10#$day_of_year))
    days_in_year=$((10#$days_in_year))
    pct=$((day_of_year * 100 / days_in_year))
    out+="${nl}${year} (${pct}%)${nl}${nl}"
  else
    out+="${nl}${year}${nl}${nl}"
  fi

  local months=("Jan" "Feb" "Mar" "Apr" "May" "Jun" "Jul" "Aug" "Sep" "Oct" "Nov" "Dec")
  for m in $(seq 1 12); do
    local month_name="${months[$((m-1))]}"
    local mm
    mm=$(printf '%02d' "$m")
    local dim_count
    dim_count=$((10#$(days_in_month "$year" "$mm")))

    local past_month=false future_month=false
    $is_current_year && [[ $m -lt $cur_month ]] && past_month=true
    $is_current_year && [[ $m -gt $cur_month ]] && future_month=true

    # Precompute date strings and XP values
    local month_total=0
    local date_strs=() day_xps=()
    for d in $(seq 1 "$dim_count"); do
      local dd
      dd=$(printf '%02d' "$d")
      local ds="${year}-${mm}-${dd}"
      date_strs+=("$ds")
      local dxp=$(( ${day_tasks["$ds"]:-0} + ${day_bonus["$ds"]:-0} + ${day_streak["$ds"]:-0} ))
      day_xps+=("$dxp")
      month_total=$((month_total + dxp))
    done
    year_total=$((year_total + month_total))

    # Header row
    local hdr=""
    if $past_month; then
      hdr+="${dim}${month_name}"
      for d in $(seq 1 "$dim_count"); do
        hdr+=$(printf ' %2d' "$d")
      done
      hdr+="${reset}"
    else
      hdr+="$month_name"
      for idx in "${!date_strs[@]}"; do
        local ds="${date_strs[$idx]}"
        local d=$((idx + 1))
        if [[ "$ds" == "$today" ]]; then
          hdr+=$(printf ' %s%2d%s' "$green" "$d" "$reset")
        elif [[ "$ds" < "$today" ]]; then
          hdr+=$(printf ' %s%2d%s' "$dim" "$d" "$reset")
        else
          hdr+=$(printf ' %2d' "$d")
        fi
      done
    fi
    out+="${hdr}${nl}"

    # Data row
    if ! ($future_month && [[ $month_total -eq 0 ]]); then
      local drow=""
      if $past_month; then
        drow+="${dim}$(printf '%3d' "$month_total")"
      else
        drow+=$(printf '%3d' "$month_total")
      fi
      for idx in "${!date_strs[@]}"; do
        local ds="${date_strs[$idx]}"
        local dxp="${day_xps[$idx]}"
        if [[ $dxp -gt 0 ]]; then
          if $past_month || [[ "$ds" < "$today" ]]; then
            drow+="${dim}$(printf ' %2d' "$dxp")${reset}"
          else
            drow+=$(printf ' %2d' "$dxp")
          fi
        elif [[ "$ds" > "$today" ]]; then
          drow+='   '
        else
          drow+="${dim}  ×${reset}"
        fi
      done
      if $past_month; then drow+="${reset}"; fi
      out+="${drow}${nl}"
    else
      out+="${nl}"
    fi
  done

  local level=$((year_total / 50))
  out+="Streak: ${streak}   Level: ${level}   Total: ${year_total} XP${nl}"

  printf '%s' "$out"
}

cmd_log_init() {
  local target_date="${1:-$(date +%Y-%m-%d)}"
  local target_week
  target_week=$(iso_week_for_date "$target_date")
  local log_dir="$VAULT_ROOT/41 projects/block-buster"
  local log_file="$log_dir/week-${target_week}.md"

  if [[ -f "$log_file" ]]; then
    echo "$log_file"
    return 0
  fi

  local template="$VAULT_ROOT/templates/Weekly Log.md"
  if [[ ! -f "$template" ]]; then
    echo "Error: template not found: $template" >&2
    exit 1
  fi

  [[ -d "$log_dir" ]] || mkdir -p "$log_dir"

  local start_end
  start_end=$(week_start_end "$target_week")
  local week_start week_end
  week_start=$(cut -f1 <<< "$start_end")
  week_end=$(cut -f2 <<< "$start_end")

  sed -e "s/^week:$/week: ${target_week}/" \
      -e "s/^start:$/start: ${week_start}/" \
      -e "s/^end:$/end: ${week_end}/" \
      "$template" > "$log_file"
  echo "$log_file"
}

collect_sleep_dates() {
  local log_dir="$VAULT_ROOT/41 projects/block-buster"
  for f in "$log_dir"/week-*.md; do
    [[ -f "$f" ]] || continue
    local fm sleep_val
    fm=$(extract_frontmatter "$f")
    sleep_val=$(get_field "sleep" "$fm")
    if [[ -n "$sleep_val" && "$sleep_val" != "[]" ]]; then
      echo "$sleep_val" | tr ',' '\n' | sed 's/^[[:space:]]*//' | grep '[0-9]'
    fi
  done | sort -u
}

cmd_notes() {
  list_notes "$VAULT_ROOT/30 notes"
}

# --- Main ---

# Parse --project flag before subcommand
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      [[ $# -lt 2 ]] && { echo "Error: --project requires a name" >&2; exit 1; }
      PROJECT_FLAG="$2"
      shift 2
      ;;
    *) break ;;
  esac
done

resolve_config

case "${1:-}" in
  config)      cmd_config ;;
  context)     cmd_context ;;
  checkpoints) shift; cmd_checkpoints "$@" ;;
  get)         shift; cmd_get "$@" ;;
  search)      shift; cmd_search "$@" ;;
  update)      cmd_update ;;
  projects)    cmd_projects ;;
  cards)       cmd_cards ;;
  notes)       cmd_notes ;;
  xp)          shift; cmd_xp "$@" ;;
  log-init)    shift; cmd_log_init "$@" ;;
  *)
    echo "Usage: vault-cli [--project <name>] {config|context|checkpoints|get|search|update|projects|cards|notes|xp|log-init}" >&2
    echo "" >&2
    echo "  --project <name>        Override project (resolved via root config)" >&2
    echo "  config                  Print resolved config JSON" >&2
    echo "  context                 Print project context.md" >&2
    echo "  checkpoints [view]      Query project checkpoints (All|Incomplete|Done|Stats)" >&2
    echo "  get <fragment>          Find and read a note/card/reference/checkpoint by name" >&2
    echo "  search <query> [-n N]   Search vault via qmd" >&2
    echo "  update                  Re-index and re-embed vault collection" >&2
    echo "  projects                List active projects" >&2
    echo "  cards                   List all cards with metadata" >&2
    echo "  notes                   List all notes with metadata" >&2
    echo "  xp [YEAR]               XP report: calendar, streak, level" >&2
    echo "  log-init [DATE]         Create weekly log from vault template" >&2
    exit 1
    ;;
esac
