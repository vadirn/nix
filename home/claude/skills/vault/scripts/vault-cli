#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
SCHEMA_DIR="$SCRIPT_DIR/../schemas"
VAULT_ROOT=""
PROJECT_PATH=""
PROJECTS_PATH=""
PROJECT_FLAG=""

# --- Config resolution ---

validate_config() {
  local cfg="$1"
  local schema="$2"
  local errors
  if ! errors=$(check-jsonschema --schemafile "$schema" "$cfg" 2>&1); then
    echo "Error: invalid config $cfg" >&2
    echo "$errors" >&2
    exit 1
  fi
}

resolve_config() {
  # Layer 1: Walk up from cwd for project config
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    local cfg="$dir/.claude/.vault.config.json"
    if [[ -f "$cfg" ]]; then
      validate_config "$cfg" "$SCHEMA_DIR/project.config.schema.json"
      local fields
      fields=$(jq -r '[.vault_root, .project_path] | @tsv' "$cfg")
      VAULT_ROOT=$(cut -f1 <<< "$fields")
      PROJECT_PATH=$(cut -f2 <<< "$fields")
      break
    fi
    dir="$(dirname "$dir")"
  done

  # Layer 2: Root config for vault_root and projects_path
  local root_cfg="$HOME/.claude/.vault.config.json"
  if [[ -f "$root_cfg" ]]; then
    validate_config "$root_cfg" "$SCHEMA_DIR/root.config.schema.json"
    local root_fields
    root_fields=$(jq -r '[.vault_root, .projects_path] | @tsv' "$root_cfg")
    [[ -z "$VAULT_ROOT" ]] && VAULT_ROOT=$(cut -f1 <<< "$root_fields")
    PROJECTS_PATH=$(cut -f2 <<< "$root_fields")
  fi

  # Layer 3: --project flag overrides PROJECT_PATH
  if [[ -n "$PROJECT_FLAG" ]]; then
    if [[ -z "$VAULT_ROOT" ]]; then
      echo "Error: --project requires vault_root (set in root or project config)" >&2
      exit 1
    fi
    local pp="${PROJECTS_PATH:-41 projects}"
    PROJECT_PATH="$VAULT_ROOT/$pp/$PROJECT_FLAG"
  fi

  # Require vault_root from config
  if [[ -z "$VAULT_ROOT" ]]; then
    echo "Error: no vault config found." >&2
    echo "Create ~/.claude/.vault.config.json with:" >&2
    echo '  { "vault_root": "/absolute/path/to/vault", "projects_path": "41 projects" }' >&2
    exit 1
  fi
}

# --- Helpers ---

# --- Subcommands ---

require_project() {
  if [[ -z "$PROJECT_PATH" ]]; then
    echo "Error: no project resolved (use --project <name> or add .claude/.vault.config.json)" >&2
    exit 1
  fi
}

cmd_config() {
  local json
  json=$(jq -n --arg vr "$VAULT_ROOT" --arg pp "$PROJECTS_PATH" --arg ppath "$PROJECT_PATH" \
    '{vault_root: $vr} + (if $pp != "" then {projects_path: $pp} else {} end) + (if $ppath != "" then {project_path: $ppath} else {} end)')
  echo "$json"
}

cmd_context() {
  require_project
  if [[ -f "$PROJECT_PATH/context.md" ]]; then
    cat "$PROJECT_PATH/context.md"
  fi
}

cmd_checkpoints() {
  require_project
  local view="${1:-All}"
  vault-query query "$PROJECT_PATH/Checkpoints.base" --view "$view" --vault-root "$VAULT_ROOT"
}

cmd_get() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: vault-cli get <name-fragment>" >&2
    exit 1
  fi
  local fragment="$1"
  local matches=()

  while IFS= read -r line; do
    matches+=("$VAULT_ROOT/$line")
  done < <(vault-query resolve "$fragment" --vault-root "$VAULT_ROOT")

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "No matches for '$fragment'" >&2
    exit 1
  elif [[ ${#matches[@]} -eq 1 ]]; then
    echo "${matches[0]}"
    echo "---"
    cat "${matches[0]}"
  else
    for m in "${matches[@]}"; do
      echo "$m"
    done
  fi
}

cmd_search() {
  if [[ $# -lt 1 ]]; then
    echo "Usage: vault-cli search <query>" >&2
    exit 1
  fi
  local query="$1"
  shift
  vault-query search "$query" --vault-root "$VAULT_ROOT" "$@"
}

cmd_projects() {
  local base_path="$VAULT_ROOT/90 bases/Projects.base"

  # Try vault-query first, fall back to file listing
  if command -v vault-query >/dev/null 2>&1 && [[ -f "$base_path" ]]; then
    vault-query query "$base_path" --view "Активные проекты" --vault-root "$VAULT_ROOT"
    return
  fi

  # Fallback: find project notes
  echo "# Fallback: file-based project listing" >&2
  find "$VAULT_ROOT/41 projects" -maxdepth 2 -name '*.md' -not -name 'checkpoint-*' -not -name 'context.md' -not -name 'SKILL.md' -not -name 'start.md' -not -name 'save.md' | sort
}


cmd_cards() {
  vault-query list "20 cards" --vault-root "$VAULT_ROOT" --fields reference
}

# Detect GNU vs BSD date once
if date --version >/dev/null 2>&1; then
  IS_GNU_DATE=true
else
  IS_GNU_DATE=false
fi

iso_week_for_date() {
  local d="${1:-$(date +%Y-%m-%d)}"
  if $IS_GNU_DATE; then
    date -d "$d" +%G-W%V
  else
    date -j -f "%Y-%m-%d" "$d" +%G-W%V
  fi
}

week_start_end() {
  local week="$1"
  local year="${week%%-W*}"
  local wnum="${week##*-W}"
  if $IS_GNU_DATE; then
    local start end
    start=$(date -d "${year}-01-04 +$((( ${wnum#0} - 1) * 7)) days -$(date -d "${year}-01-04" +%u) days +1 day" +%Y-%m-%d)
    end=$(date -d "$start +6 days" +%Y-%m-%d)
  else
    local jan4_dow start end
    jan4_dow=$(date -j -f "%Y-%m-%d" "${year}-01-04" +%u)
    start=$(date -j -v+"$(( (${wnum#0} - 1) * 7 - jan4_dow + 1 ))d" -f "%Y-%m-%d" "${year}-01-04" +%Y-%m-%d)
    end=$(date -j -v+6d -f "%Y-%m-%d" "$start" +%Y-%m-%d)
  fi
  printf '%s\t%s' "$start" "$end"
}

# Offset a date by N days (positive = forward, negative = backward)
date_offset_days() {
  local d="$1" n="$2"
  if $IS_GNU_DATE; then
    date -d "$d + $n days" +%Y-%m-%d
  else
    if [[ $n -ge 0 ]]; then
      date -j -v+"${n}d" -f "%Y-%m-%d" "$d" +%Y-%m-%d
    else
      date -j -v"${n}d" -f "%Y-%m-%d" "$d" +%Y-%m-%d
    fi
  fi
}

resolve_log_date() {
  local input="${1:-}"
  if [[ -z "$input" ]]; then
    iso_week_for_date "$(date +%Y-%m-%d)"
    return
  fi
  case "$input" in
    last|prev)
      local d
      d=$(date_offset_days "$(date +%Y-%m-%d)" -7)
      iso_week_for_date "$d"
      ;;
    next)
      local d
      d=$(date_offset_days "$(date +%Y-%m-%d)" 7)
      iso_week_for_date "$d"
      ;;
    [0-9]|[0-9][0-9])
      printf '%s-W%02d' "$(date +%G)" "${input#0}"
      ;;
    [wW][0-9]|[wW][0-9][0-9])
      local n="${input:1}"
      printf '%s-W%02d' "$(date +%G)" "${n#0}"
      ;;
    [0-9][0-9][0-9][0-9]-[wW][0-9]|[0-9][0-9][0-9][0-9]-[wW][0-9][0-9])
      local year="${input:0:4}"
      local n="${input:6}"
      printf '%s-W%02d' "$year" "${n#0}"
      ;;
    [0-9][0-9][0-9][0-9][wW][0-9]|[0-9][0-9][0-9][0-9][wW][0-9][0-9])
      local year="${input:0:4}"
      local n="${input:5}"
      printf '%s-W%02d' "$year" "${n#0}"
      ;;
    [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
      iso_week_for_date "$input"
      ;;
    *)
      echo "Error: unknown date format '$input'" >&2
      exit 1
      ;;
  esac
}

cmd_xp() {
  ruby "$SCRIPT_DIR/vault-xp.rb" "$VAULT_ROOT" "$@"
}

cmd_log() {
  local target_week
  target_week=$(resolve_log_date "${1:-}")
  local log_dir="$VAULT_ROOT/41 projects/block-buster"
  local log_file="$log_dir/${target_week,,}.md"

  if [[ -f "$log_file" ]]; then
    echo "$log_file"
    return 0
  fi

  # Guard: don't create files for past weeks
  local start_end
  start_end=$(week_start_end "$target_week")
  local week_end
  week_end=$(cut -f2 <<< "$start_end")
  local today
  today=$(date +%Y-%m-%d)
  if [[ "$week_end" < "$today" ]]; then
    echo "Error: no log for past week ${target_week} (ended ${week_end})" >&2
    exit 1
  fi

  local template="$VAULT_ROOT/templates/Weekly Log.md"
  if [[ ! -f "$template" ]]; then
    echo "Error: template not found: $template" >&2
    exit 1
  fi

  [[ -d "$log_dir" ]] || mkdir -p "$log_dir"

  local week_start
  week_start=$(cut -f1 <<< "$start_end")

  sed -e "s/^week:$/week: ${target_week}/" \
      -e "s/^start:$/start: ${week_start}/" \
      -e "s/^end:$/end: ${week_end}/" \
      "$template" > "$log_file"
  echo "$log_file"
}


cmd_notes() {
  vault-query list "30 notes" --vault-root "$VAULT_ROOT"
}

# --- Main ---

# Parse --project flag before subcommand
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      [[ $# -lt 2 ]] && { echo "Error: --project requires a name" >&2; exit 1; }
      PROJECT_FLAG="$2"
      shift 2
      ;;
    *) break ;;
  esac
done

resolve_config

case "${1:-}" in
  config)      cmd_config ;;
  context)     cmd_context ;;
  checkpoints) shift; cmd_checkpoints "$@" ;;
  get)         shift; cmd_get "$@" ;;
  search)      shift; cmd_search "$@" ;;
  projects)    cmd_projects ;;
  cards)       cmd_cards ;;
  notes)       cmd_notes ;;
  xp)          shift; cmd_xp "$@" ;;
  log)         shift; cmd_log "$@" ;;
  *)
    echo "Usage: vault-cli [--project <name>] {config|context|checkpoints|get|search|projects|cards|notes|xp|log}" >&2
    echo "" >&2
    echo "  --project <name>        Override project (resolved via root config)" >&2
    echo "  config                  Print resolved config JSON" >&2
    echo "  context                 Print project context.md" >&2
    echo "  checkpoints [view]      Query project checkpoints (All|Incomplete|Done|Stats)" >&2
    echo "  get <fragment>          Find and read a note/card/reference/checkpoint by name" >&2
    echo "  search <query>          BM25 full-text search (--regex for grep mode)" >&2
    echo "  projects                List active projects" >&2
    echo "  cards                   List all cards with metadata" >&2
    echo "  notes                   List all notes with metadata" >&2
    echo "  xp [YEAR]               XP report: calendar, streak, level" >&2
    echo "  log [DATE|WEEK|last|next] Open or create weekly log" >&2
    exit 1
    ;;
esac
